rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }
    
    function isValidId(id) { 
        return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isStrictlySignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // Explicit Admin Backdoor using your verified Google Account email
    function isAdmin() {
      return isStrictlySignedIn() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
         request.auth.token.email == 'ishansrivastavaaa@gmail.com');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'createdAt', 'role']) &&
             data.email is string && data.email.size() <= 255 &&
             data.name is string && data.name.size() <= 100 &&
             data.createdAt is timestamp &&
             data.role in ['user', 'admin'] &&
             (data.keys().hasAll(['avatar']) ? (data.avatar is string && data.avatar.size() <= 1024) : true);
    }
    
    function isValidStay(data) {
      return data.keys().hasAll(['name', 'location', 'image', 'type', 'description', 'createdAt', 'ownerId', 'status']) &&
             data.name is string && data.name.size() <= 200 &&
             data.location is string && data.location.size() <= 200 &&
             data.image is string && data.image.size() <= 1024 &&
             data.type in ['PG', 'Hostel', 'Flat'] &&
             data.description is string && data.description.size() <= 5000 &&
             data.createdAt is timestamp &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (data.keys().hasAll(['price']) ? (data.price is number) : true) &&
             (data.keys().hasAll(['rating']) ? (data.rating is number) : true) &&
             (data.keys().hasAll(['distanceToUni']) ? (data.distanceToUni is string && data.distanceToUni.size() <= 100) : true) &&
             (data.keys().hasAll(['amenities']) ? (data.amenities is list && data.amenities.size() <= 20 && (data.amenities.size() == 0 || data.amenities[0] is string)) : true);
    }
    
    function isValidViewingRequest(data) {
      return data.keys().hasAll(['userId', 'stayId', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.stayId is string && data.stayId.size() <= 128 &&
             data.status in ['pending', 'contacted', 'fulfilled', 'cancelled'] &&
             data.createdAt is timestamp &&
             (data.keys().hasAll(['message']) ? (data.message is string && data.message.size() <= 1000) : true);
    }

    match /users/{userId} {
      allow read: if isStrictlySignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isStrictlySignedIn() && 
                       request.auth.uid == userId &&
                       isValidUser(incoming()) &&
                       incoming().createdAt == request.time &&
                       incoming().role == 'user';
      allow update: if isStrictlySignedIn() &&
                       request.auth.uid == userId &&
                       isValidUser(incoming()) &&
                       incoming().role == existing().role &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'updatedAt']) &&
                       (incoming().keys().hasAll(['updatedAt']) ? incoming().updatedAt == request.time : true);
    }
    
    match /admins/{adminId} {
      allow read: if isStrictlySignedIn() && request.auth.uid == adminId;
      allow write: if false; 
    }

    match /stays/{stayId} {
      allow get: if resource.data.status == 'approved' || (isStrictlySignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow list: if resource.data.status == 'approved' || (isStrictlySignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      
      allow create: if isStrictlySignedIn() && 
                       isValidId(stayId) && 
                       isValidStay(incoming()) && 
                       incoming().createdAt == request.time &&
                       incoming().ownerId == request.auth.uid &&
                       incoming().status == 'pending';
                       
      allow update: if isStrictlySignedIn() && 
                       isValidId(stayId) && 
                       isValidStay(incoming()) &&
                       incoming().ownerId == existing().ownerId &&
                       incoming().createdAt == existing().createdAt &&
                       (
                         (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                         // Allow system to update rating and reviewsCount 
                         (isStrictlySignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'reviewsCount']))
                       );
                       
      allow delete: if isAdmin() && isValidId(stayId);
    }
    
    match /viewing_requests/{requestId} {
      allow get: if isStrictlySignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || exists(/databases/$(database)/documents/stays/$(resource.data.stayId)) && get(/databases/$(database)/documents/stays/$(resource.data.stayId)).data.ownerId == request.auth.uid);
      allow list: if isStrictlySignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || request.query.limit <= 100); // Admin or owner filtering handled on client with rules
      
      allow create: if isStrictlySignedIn() && 
                       isValidId(requestId) &&
                       isValidViewingRequest(incoming()) && 
                       incoming().createdAt == request.time &&
                       incoming().status == 'pending' &&
                       exists(/databases/$(database)/documents/stays/$(incoming().stayId));
                       
      allow update: if isStrictlySignedIn() &&
                       isValidId(requestId) &&
                       isValidViewingRequest(incoming()) &&
                       incoming().userId == existing().userId &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().stayId == existing().stayId &&
                       (
                         (request.auth.uid == existing().userId && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) && incoming().status == 'cancelled') ||
                         (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                         (exists(/databases/$(database)/documents/stays/$(existing().stayId)) && get(/databases/$(database)/documents/stays/$(existing().stayId)).data.ownerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
                       );
                       
      allow delete: if isAdmin() && isValidId(requestId);
    }

    match /favorites/{favoriteId} {
      allow read: if isStrictlySignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isStrictlySignedIn() && incoming().userId == request.auth.uid && incoming().keys().hasAll(['userId', 'stayId', 'createdAt']);
      allow delete: if isStrictlySignedIn() && resource.data.userId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if isStrictlySignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isStrictlySignedIn() && request.auth.uid in incoming().participants && incoming().keys().hasAll(['participants', 'stayId', 'createdAt', 'updatedAt']);
      allow update: if isStrictlySignedIn() && request.auth.uid in existing().participants && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);
      
      match /messages/{messageId} {
        allow read: if isStrictlySignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isStrictlySignedIn() && 
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                         incoming().senderId == request.auth.uid &&
                         incoming().keys().hasAll(['senderId', 'text', 'createdAt']);
      }
    }
  }
}
